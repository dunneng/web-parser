{
  "name": "web-parser",
  "version": "1.2.0",
  "description": "网页源码解析器 - 可视化提取网页数据并导出Excel",
  "author": "WebParser",
  "main": "main.js",
  "scripts": {
    "start": "electron.cmd .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.webparser.app",
    "productName": "WebParser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "webview-preload.js",
      "tab-browser-preload.js",
      "renderer/**/*",
      "tab-browser.html",
      "tab-browser.css",
      "tab-browser.js",
      "python/**/*",
      "!python/dist",
      "!python/build",
      "!python/__pycache__",
      "!python/python-backend/_internal",
      "!python/data",
      "!python/cookies",
      "!python/models",
      "!python/wheels",
      "!python/static",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": ["**/*", "!dist/**", "!build/**", "!__pycache__/**", "!data/**", "!cookies/**", "!models/**", "!wheels/**", "!static/**", "!python-backend/_internal/**", "!*.spec"]
      }
    ],
    "win": {
      "target": "portable",
      "icon": null,
      "forceCodeSigning": false
    },
    "portable": {
      "artifactName": "WebParser_${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "latest"
  }
}
