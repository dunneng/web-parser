  /** 将 schema 数据填入 UI */
  function applySchemaToUI(schema) {
    schemaCurrentName = schema.name || '';
    schemaName.value = schema.name || '';


    // 检查是否为链路模式方案
    var isChainMode = schema.mode === 'chain' || (schema.fields && schema.fields.length > 0 && schema.fields[0].type === 'chain');
    if (isChainMode && schema.chainSegments && schema.chainSegments.length > 0) {
      // 恢复链路模式
      schemaMode = 'chain';
      switchSchemaTab('chain');
      // 恢复链路输入和类型按钮
      schemaChainInput.value = schema.deepestSelector || (schema.fields[0] ? schema.fields[0].selector : '') || '';
      var chainType = schema.chainType || 'css';
      var cssBtn = document.getElementById('schemaTypeCss');
      var xpBtn = document.getElementById('schemaTypeXpath');
      if (cssBtn) cssBtn.classList.toggle('active', chainType === 'css');
      if (xpBtn) xpBtn.classList.toggle('active', chainType === 'xpath');
      // 恢复 chainSegments
      chainSegments = schema.chainSegments;
      // 用 fields 中的 attr/name 回填到对应的 chainSegments
      if (schema.fields) {
        schema.fields.forEach(function(f) {
          if (f.type === 'chain') {
            var ci = f.chainIndex;
            if (f.subChain) {
              // 子链路字段：找到匹配的 subChain，回填到 chainSegments
              var subIdx = f.subChain.chainIndex;
              if (chainSegments[ci] && chainSegments[ci].subChains) {
                // 找匹配的子链路（按 selector + chainType 匹配）
                var matched = null;
                chainSegments[ci].subChains.forEach(function(sc) {
                  if (sc.selector === f.subChain.selector && sc.chainType === f.subChain.chainType) { matched = sc; }
                });
                if (matched && matched.chainSegments && matched.chainSegments[subIdx]) {
                  if (!matched.chainSegments[subIdx].extractions) matched.chainSegments[subIdx].extractions = [];
                  matched.chainSegments[subIdx].extractions.push({ attr: f.isText ? '$text' : (f.attr || ''), name: f.name || '' });
                }
              }
            } else if (ci >= 0 && ci < chainSegments.length) {
              if (!chainSegments[ci].extractions) chainSegments[ci].extractions = [];
              chainSegments[ci].extractions.push({ attr: f.isText ? '$text' : (f.attr || ''), name: f.name || '' });
            }
          }
        });
      }
      renderChainLayers();
    } else {
      // 手动模式
