    const icon = treeIcons[label] || '';
    let html = '<span class="toggle"></span><span class="node-icon">' + icon + '</span><span class="node-label">' + label + '</span>';
    if (count !== undefined && count !== null) {
      html += '<span class="node-count">' + count + '</span>';
