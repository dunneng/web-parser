                var cp = parsed[cursorKeys[k]] ? cursorKeys[k] : 'data.' + cursorKeys[k];
                $('#pfCursorPath').value = cp;
              }
              break;
            }
          }
          $('#pfCursorRow').style.display = $('#pfPaginationType').value === 'cursor' ? 'flex' : 'none';
        }
      } catch (e) {}
    }
  }

