  // ──────── 查询执行 ────────
  function bindQueryEvents() {
    btnQuery.addEventListener('click', executeQuery);
    queryInput.addEventListener('keydown', e => { if (e.key === 'Enter') executeQuery(); });
    querySearch.addEventListener('input', () => {
      const mode = queryContainer.dataset.mode;
      if (mode === '__source__') {
        if (cachedSourceHtml) renderSourceInResults(cachedSourceHtml);
        return;
      }
      if (mode === '__dom__') {
        // DOM 树搜索在 showDomTreePanel 中处理
        return;
      }
      if (mode === '__api_response__' || mode === '__api_json__' || mode === '__api_headers__') {
        // API 响应相关模式自行处理搜索
        return;
      }
      const q = querySearch.value.trim().toLowerCase();
      renderQueryTable(q ? queryResults.filter(row => Object.values(row).some(v => String(v).toLowerCase().includes(q))) : queryResults);
    });
    // 工具栏全选 ←→ 表头全选 双向同步
    queryCheckAll.addEventListener('change', function() {
      var checked = queryCheckAll.checked;
      var rca = queryResultsDiv.querySelector('.result-check-all');
      if (rca) rca.checked = checked;
      queryResultsDiv.querySelectorAll('.result-checkbox').forEach(function(cb) { cb.checked = checked; });
      updateRowSelection();
    });
    // 全局子节点分隔符变更时自动重新查询并持久化
    globalChildDelimInput.addEventListener('change', function() {
