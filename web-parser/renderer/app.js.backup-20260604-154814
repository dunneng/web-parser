        }
      }
      // 手动 tab：元素可能不在 editorItems 中，直接构造
      if (!found) {
        childrenData.push({
          elementInfo: { tag: ch.tag || 'span', text: ch.text || '', class: '', id: '', href: '', src: '', selectors: [{ selector: ch.css, label: '手动' }] },
