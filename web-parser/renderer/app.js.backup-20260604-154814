        addTreeItem(gApi, 'JSON 树', 'api-json-tree', null);
      } catch (e) {}
    }
    addTreeItem(gApi, '响应头', 'api-headers', null);
    addTreeItem(gApi, '状态信息', 'api-status', null);

    var g2 = startGroup(root, '数据提取');
