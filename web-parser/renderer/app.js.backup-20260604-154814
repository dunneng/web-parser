        if (proxyPort) proxyPort.value = p.port;
        if (proxyProtocol) proxyProtocol.value = p.protocol || 'http';
      }
    })();

    // ── 反爬脚本设置 ──
    loadStealthConfig();
    renderStealthUI();
    bindStealthEvents();

    // ── 行为模拟设置 ──
    loadBehaveConfig();
    bindBehaveEvents();
