  function addToClipboard(text, source) {
    if (!text) return;
    text = String(text).substring(0, 10000);
    // 去重复
    clipboardHistory = clipboardHistory.filter(function(item) { return item.text !== text; });
    clipboardHistory.unshift({ text: text, source: source || '未知', time: new Date().toLocaleTimeString() });
    if (clipboardHistory.length > CLIPBOARD_MAX) clipboardHistory.pop();
    // 同步到系统剪贴板
    window.api.writeClipboard(text);
    renderClipboardPanel();
  }

