  // ── 动态网页等待策略 ──

  function waitForNetworkIdle(idleMs, maxWait) {
    return new Promise(function(resolve) {
      var start = Date.now();
      var check = function() {
        if (Date.now() - start >= maxWait) return resolve();
        try {
          webview.executeJavaScript('(function(){var e=window.__parser&&window.__parser.networkInterceptor&&window.__parser.networkInterceptor.intercepted;if(!e||!e.length)return!0;return Date.now()-e[e.length-1].time>' + idleMs + ';})()').then(function(r) {
            if (r) resolve();
            else setTimeout(check, 500);
          }).catch(function() { resolve(); });
        } catch(e) { resolve(); }
      };
      check();
    });
  }

  function waitForSelector(selector, maxWait) {
    return new Promise(function(resolve) {
      var start = Date.now();
      var check = function() {
        if (Date.now() - start >= maxWait) return resolve();
        try {
          webview.executeJavaScript('(function(){return!!document.querySelector(\'' + selector.replace(/'/g, "\\'") + '\');})()').then(function(r) {
            if (r) resolve();
            else setTimeout(check, 500);
          }).catch(function() { resolve(); });
        } catch(e) { resolve(); }
      };
      check();
    });
  }

  function confirmBatchConfig() {
    var selector = $('#batchSelector').value.trim();
    var selectorType = $('#batchSelectorType').value || 'css';
    var newTasks = [];

    if (batchCurrentMode === 'localfiles') {
      if (batchLocalFiles.length === 0) { alert('请先添加 HTML 文件'); return; }
      batchLocalFiles.forEach(function(f) {
        var localUrl = toLocalHtmlUrl(f.path);
        newTasks.push({ url: localUrl, q: f.name, page: '-' });
      });
    } else if (batchCurrentMode === 'urllist') {
      var raw = $('#batchUrlList').value.trim();
      var lines = raw.split(/[\n]+/).map(function(s) { return s.trim(); }).filter(Boolean);
      var ps = parseInt($('#batchUrlListPageStart').value) || 1;
      var pe = parseInt($('#batchUrlListPageEnd').value) || 1;
      lines.forEach(function(line) {
        if (/\{page\}/.test(line)) {
          for (var p = ps; p <= pe; p++) {
            newTasks.push({ url: line.replace(/\{page\}/g, p), q: line, page: p });
          }
        } else {
          newTasks.push({ url: line, q: line, page: '-' });
        }
      });
    } else {
      var urlTemplate = $('#batchUrlTemplate').value.trim();
      var queriesRaw = $('#batchQueries').value.trim();
      var ps = parseInt($('#batchPageStart').value) || 1;
      var pe = parseInt($('#batchPageEnd').value) || 1;
      var tagModeEl = document.querySelector('input[name="batchTagMode"]:checked');
      var tagMode = tagModeEl ? tagModeEl.value : 'cartesian';
      var isClickNext = batchDynamicStrategy.value === 'clickNext';

      if (!urlTemplate) { setStatus('请输入 URL 模板'); return; }
      var queries = queriesRaw ? queriesRaw.split(/[\n,]+/).map(function(s) { return s.trim(); }).filter(Boolean) : [''];
      if (isClickNext) {
        // 翻页按钮点击模式：每个搜索词只生成 1 个任务
        for (var qi = 0; qi < queries.length; qi++) {
          newTasks.push({ url: urlTemplate.replace(/\{q\}/g, encodeURIComponent(queries[qi])).replace(/\{page\}/g, ps), q: queries[qi], page: 'clickNext' });
        }
      } else if (batchDynamicStrategy.value === 'manual') {
        // 手动翻页模式：每个搜索词只生成 1 个任务，用户手动点翻页
        for (var qi = 0; qi < queries.length; qi++) {
          newTasks.push({ url: urlTemplate.replace(/\{q\}/g, encodeURIComponent(queries[qi])).replace(/\{page\}/g, ps), q: queries[qi], page: 'manual' });
        }
      } else if (tagMode === 'cartesian') {
        for (var qi = 0; qi < queries.length; qi++) {
          for (var pi = ps; pi <= pe; pi++) {
            newTasks.push({ url: urlTemplate.replace(/\{q\}/g, encodeURIComponent(queries[qi])).replace(/\{page\}/g, pi), q: queries[qi], page: pi });
          }
        }
      } else {
        for (var i = 0; i < Math.max(queries.length, pe - ps + 1); i++) {
          var q = queries[i] || queries[queries.length - 1] || '';
          var p = ps + i;
          if (p > pe) break;
          newTasks.push({ url: urlTemplate.replace(/\{q\}/g, encodeURIComponent(q)).replace(/\{page\}/g, p), q: q, page: p });
        }
      }
    }

    if (newTasks.length === 0) { setStatus('没有生成任何任务'); return; }
    closeBatchModal();

    // 读取 clickNext 参数（只读一次，避免 DOM 状态变化）
    var _isClickNext = batchDynamicStrategy.value === 'clickNext';
    var _isManual = batchDynamicStrategy.value === 'manual';
    var _cnSelector = _isClickNext ? ($('#batchClickNextSelector').value || '').trim() : '';
    var _cnInterval = (_isClickNext || _isManual) ? (parseInt($('#batchClickNextInterval').value) || 2000) : 0;
    var _cnPreWait = _isClickNext ? (parseInt($('#batchClickNextPreWait').value) || 500) : 0;
    var _cnMaxPages = (_isClickNext || _isManual) ? (parseInt($('#batchPageEnd').value) || 10) : 0;

    batchTasks = [];
    batchAllResults = [];
    batchTaskIdCounter = 0;
    newTasks.forEach(function(t) {
      batchTasks.push({ id: ++batchTaskIdCounter, url: t.url, q: t.q, page: t.page, selector: selector, selectorType: selectorType, status: 'pending', rowCount: 0, error: null, results: null,
        clickNextSelector: _cnSelector, clickNextInterval: _cnInterval, clickNextPreWait: _cnPreWait, clickNextMaxPages: _cnMaxPages });
    });

    batchTagsPanel.classList.remove('hidden');
    btnBatchLoadAll.classList.remove('hidden');
    renderBatchTags();
    fitBatchPanelToTree();
    setStatus('已生成 ' + batchTasks.length + ' 个抓取任务');

    hideAllPanels();
    queryContainer.classList.remove('hidden');
    queryContainer.dataset.mode = 'batch';
    contentTitle.textContent = '批量抓取结果';
    queryResultsDiv.innerHTML = '';
    queryResults = [];
  }

  function renderBatchTags() {
    batchTagsList.innerHTML = '';
    batchTasks.forEach(function(t) {
      var el = document.createElement('div');
      el.className = 'batch-tag ' + t.status;
      if (t.id === batchCurrentTaskId) el.classList.add('active');
      el.innerHTML = '<span class="batch-tag-dot"></span>'
        + '<span class="batch-tag-label" title="' + escapeHtml(t.url) + '">' + escapeHtml(t.q || t.url.split('/').pop() || '?') + (t.page === 'clickNext' || t.page === 'manual' ? '' : t.page !== '-' ? ' p' + t.page : '') + '</span>'
        + (t.status === 'done' ? '<span class="batch-tag-count">' + t.rowCount + '</span>' : '')
        + '<span class="batch-tag-close">&times;</span>';
      el.querySelector('.batch-tag-close').addEventListener('click', function(e2) {
        e2.stopPropagation();
        removeBatchTag(t.id);
      });
      el.addEventListener('click', function() {
        if (t.status === 'done' && t.results) {
          // 高亮当前标签
          $$('.batch-tag.active').forEach(function(tag) { tag.classList.remove('active'); });
          el.classList.add('active');
          // 预览区切到该页
          var currentUrl = webview.getURL();
          if (currentUrl !== t.url) webview.loadURL(t.url);
          // 更新树
          if (t.parseData) { parseResult = t.parseData; buildTree(parseResult); }
          // 更新结果表
          queryResults = t.results;
          renderQueryTable(t.results);
          contentTitle.textContent = '结果: ' + (t.q || t.url) + (t.page && t.page !== '-' && t.page !== 'clickNext' && t.page !== 'manual' ? ' p' + t.page : '') + ' (' + t.rowCount + '项)';
        }
      });
      batchTagsList.appendChild(el);
    });
    var pending = batchTasks.filter(function(t) { return t.status === 'pending'; }).length;
    var verify = batchTasks.filter(function(t) { return t.status === 'verify'; }).length;
    var loading = batchTasks.filter(function(t) { return t.status === 'loading'; }).length;
    var done = batchTasks.filter(function(t) { return t.status === 'done'; }).length;
    var error = batchTasks.filter(function(t) { return t.status === 'error'; }).length;
    var parts = [];
    var icoWrap = 'display:inline-flex;align-items:center;gap:2px';
    if (done) parts.push('<span style="color:var(--green);' + icoWrap + '" title="' + done + '条已完成"><span style="font-size:18px;line-height:1">●</span>' + done + '</span>');
    if (loading) parts.push('<span style="color:var(--accent);' + icoWrap + '" title="' + loading + '条进行中"><span style="font-size:13px;line-height:1">◐</span>' + loading + '</span>');
    if (pending) parts.push('<span style="color:#888;' + icoWrap + '" title="' + pending + '条等待"><span style="font-size:13px;line-height:1">○</span>' + pending + '</span>');
    if (verify) parts.push('<span style="color:#f59e0b;' + icoWrap + '" title="' + verify + '条需验证"><span style="font-size:13px;line-height:1">⚠</span>' + verify + '</span>');
    if (error) parts.push('<span style="color:var(--red);' + icoWrap + '" title="' + error + '条失败"><span style="font-size:13px;line-height:1">✕</span>' + error + '</span>');
    batchTagsCount.innerHTML = parts.join(' ') || '0个';
    // 显示/隐藏继续按钮
    var hasVerify = batchTasks.some(function(t) { return t.status === 'verify'; });
    btnBatchContinue.classList.toggle('hidden', !hasVerify);
    // 更新合并导出按钮
    updateMergeExportBtn();
    fitBatchPanelToTree();
  }

  function removeBatchTag(id) {
    batchTasks = batchTasks.filter(function(t) { return t.id !== id; });
    if (batchTasks.length === 0) {
      batchTagsPanel.classList.add('hidden');
      btnBatchLoadAll.classList.add('hidden');
      batchAllResults = [];
    }
    renderBatchTags();
  }

  async function batchLoadAll() {
    if (batchLoadRunning) { batchLoadCancel = true; return; }
    batchLoadRunning = true;
    batchLoadCancel = false;
    batchLoadPaused = false;
    // 重试配置
    var MAX_RETRIES = batchTasks.length > 50 ? 1 : 3;  // 大批量减少重试
    var RETRY_DELAY = 2000;

    // 确保预览区可见
    webviewOverlay.classList.add('hidden');
    panelRight.style.width = '40%';
    panelLeft.style.width = '';
    btnFetch.classList.remove('hidden');
    btnElementPicker.classList.remove('hidden');
    btnBatchLoadAll.textContent = '停止';
    btnBatchLoadAll.style.background = 'var(--red)';
    btnBatchLoadAll.style.borderColor = 'var(--red)';
    btnBatchLoadAll.style.color = '#fff';

    for (var i = 0; i < batchTasks.length; i++) {
      if (batchLoadCancel) break;
      var t = batchTasks[i];
      if (t.status === 'done') continue;
      if (t.status === 'verify') {
        batchLoadPaused = true;
        break;
      }
      batchCurrentTaskId = t.id;
      t.status = 'loading';
      renderBatchTags();
      try {
        if (t.page === 'clickNext') {
          // ── 翻页按钮点击模式 ──
          var nextSel = t.clickNextSelector;
          var clickInterval = t.clickNextInterval || 2000;
          var preWait = t.clickNextPreWait || 500;
          var maxPages = t.clickNextMaxPages || 10;
          var cnPage = 0;
          var allResults = [];
          var wasFirstLoad = false;

          while (cnPage < maxPages) {
            if (batchLoadCancel) break;
            cnPage++;
            if (cnPage === 1) {
              // 首页：正常 loadURL
              var loaded = false;
              var loadPromise = new Promise(function(resolve) {
                var timeout = setTimeout(function() { if (!loaded) resolve(); }, 15000);
                function onLoad() {
                  if (loaded) return;
                  loaded = true;
                  clearTimeout(timeout);
                  webview.removeEventListener('did-finish-load', onLoad);
                  setTimeout(resolve, 600);
                }
                webview.addEventListener('did-finish-load', onLoad);
              });
              webview.loadURL(t.url);
              await loadPromise;
              wasFirstLoad = true;
            } else {
              // 后续页：点击"下一页"按钮
              if (preWait > 0) await sleep(preWait);
              var clicked = await webview.executeJavaScript(
                '(function(sel){var btn=document.querySelector(sel);if(btn){btn.click();return true;}return false;})(' + JSON.stringify(nextSel) + ')'
              );
              if (!clicked) break; // 按钮消失，翻页结束
              await sleep(clickInterval);
            }

            // 动态网页等待策略
            var isDynamic = (document.querySelector('input[name="batchPageType"]:checked') || {}).value === 'dynamic';
            if (isDynamic) {
              var strategy = batchDynamicStrategy.value;
              if (strategy === 'networkIdle') {
                var idleMs = parseInt($('#batchDynamicIdleMs').value) || 2000;
                var maxIdleSec = parseInt($('#batchDynamicMaxWait').value) || 30;
                await waitForNetworkIdle(idleMs, maxIdleSec * 1000);
              } else if (strategy === 'waitSelector') {
                var waitSel = ($('#batchDynamicSelector').value || '').trim();
                var selMaxSec = parseInt($('#batchDynamicSelectorMaxWait').value) || 30;
                if (waitSel) await waitForSelector(waitSel, selMaxSec * 1000);
              } else if (strategy !== 'clickNext') {
                var extraWait = parseInt($('#batchWaitMs').value) || 3000;
                await sleep(extraWait);
              }
            } else {
              await sleep(parseInt($('#batchInterval').value) || 500);
            }

            // 抓取当前页 HTML
            currentHtml = await webview.executeJavaScript('document.documentElement.outerHTML');
            if (!currentHtml) continue;

            // 获取当前页面真实 URL（翻页后 URL 可能变化）
            var cnCurrentUrl = await webview.executeJavaScript('window.location.href');
            cnCurrentUrl = cnCurrentUrl || t.url;

            // 解析
            var respAll = await fetch('http://127.0.0.1:' + pythonPort + '/api/parse/all', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ html: currentHtml }),
            });
            if (!respAll.ok) throw new Error('解析失败: ' + respAll.status);
            var pdata = await respAll.json();
            t.parseData = pdata;

            // 提取
            var _sel = t.selector || '';
            var _selType = t.selectorType || 'css';
            var pageResults;
            if (_sel) {
              var extractPath = _selType === 'xpath' ? '/api/extract/xpath' : '/api/extract/css';
              var extractLabel = _selType === 'xpath' ? 'XPath' : 'CSS';
              var respExt = await fetch('http://127.0.0.1:' + pythonPort + extractPath, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ html: currentHtml, query: _sel, child_delim: globalChildDelim }),
              });
              if (!respExt.ok) throw new Error(extractLabel + '提取失败: ' + respExt.status);
              var cdata = await respExt.json();
              pageResults = cdata.results || [];
            } else {
              pageResults = [{ '页面标题': (currentHtml.match(/<title>(.*?)<\/title>/i) || [])[1] || '', '字符数': currentHtml.length, '脚本数': (pdata.scripts || []).length }];
            }
            // 标签结果带上页码
            var tagged = pageResults.map(function(r) {
              r._batchQ = t.q;
              r._batchPage = cnPage;
              r._batchUrl = cnCurrentUrl;
              return r;
            });
            allResults = allResults.concat(tagged);
            batchAllResults = batchAllResults.concat(tagged);
            t.results = allResults;
            t.rowCount = allResults.length;
            // 为当前页追加独立标签（使用当前真实 URL）
            batchTasks.push({
              id: ++batchTaskIdCounter, url: cnCurrentUrl, q: t.q, page: cnPage,
              selector: t.selector, status: 'done', rowCount: pageResults.length, error: null,
              results: pageResults, parseData: pdata
            });
            renderBatchTags();
          }
          if (!batchLoadCancel && t.status === 'loading') t.status = 'done';
        } else if (t.page === 'manual') {
          // ── 手动翻页模式：用户手动点翻页，系统检测 URL 变化自动抓取 ──
          var mnMaxPages = t.clickNextMaxPages || 99;
          var mnPage = 0;
          var mnAllResults = [];
          var mnLastUrl = '';

          // 首页：正常加载
          var mnLoaded = false;
          var mnLoadPromise = new Promise(function(resolve) {
            var timeout = setTimeout(function() { if (!mnLoaded) resolve(); }, 15000);
            function onLoad() {
              if (mnLoaded) return;
              mnLoaded = true;
              clearTimeout(timeout);
              webview.removeEventListener('did-finish-load', onLoad);
              setTimeout(resolve, 600);
            }
            webview.addEventListener('did-finish-load', onLoad);
          });
          webview.loadURL(t.url);
          await mnLoadPromise;
          await sleep(parseInt($('#batchInterval').value) || 500);

          while (mnPage < mnMaxPages) {
            if (batchLoadCancel) break;
            mnPage++;

            // 获取当前页面真实 URL（手动翻页后 URL 变化，记录下来供后续标签点击回显）
            var mnCurrentUrl = await webview.executeJavaScript('window.location.href');
            mnCurrentUrl = mnCurrentUrl || t.url;

            // 抓取当前页
            currentHtml = await webview.executeJavaScript('document.documentElement.outerHTML');
            if (currentHtml) {
              var mnResp = await fetch('http://127.0.0.1:' + pythonPort + '/api/parse/all', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ html: currentHtml }),
              });
              if (!mnResp.ok) throw new Error('解析失败: ' + mnResp.status);
              var mnPdata = await mnResp.json();
              t.parseData = mnPdata;

              var mnPageResults;
              if (t.selector) {
                var mnCss = await fetch('http://127.0.0.1:' + pythonPort + '/api/extract/css', {
                  method: 'POST', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ html: currentHtml, query: t.selector, child_delim: globalChildDelim }),
                });
                if (!mnCss.ok) throw new Error('CSS提取失败: ' + mnCss.status);
                var mnCdata = await mnCss.json();
                mnPageResults = mnCdata.results || [];
              } else {
                mnPageResults = [{ '页面标题': (currentHtml.match(/<title>(.*?)<\/title>/i) || [])[1] || '', '字符数': currentHtml.length, '脚本数': (mnPdata.scripts || []).length }];
              }
              var mnTagged = mnPageResults.map(function(r) {
                r._batchQ = t.q;
                r._batchPage = mnPage;
                r._batchUrl = mnCurrentUrl;
                return r;
              });
              mnAllResults = mnAllResults.concat(mnTagged);
              batchAllResults = batchAllResults.concat(mnTagged);
              t.results = mnAllResults;
              t.rowCount = mnAllResults.length;
              // 为当前页追加独立标签（使用当前真实 URL，非原始 URL）
              batchTasks.push({
                id: ++batchTaskIdCounter, url: mnCurrentUrl, q: t.q, page: mnPage,
                selector: t.selector, status: 'done', rowCount: mnPageResults.length, error: null,
                results: mnPageResults, parseData: mnPdata
              });
              renderBatchTags();
              setStatus('第' + mnPage + '页已抓取，请在页面手动翻页...');
            }

            // 等待用户手动翻页（window.location.href 捕获 pushState 变化）
            mnLastUrl = await webview.executeJavaScript('window.location.href');
            var mnNavDetected = false;
            while (!batchLoadCancel && !mnNavDetected) {
              await sleep(800);
              try {
                var curUrl = await webview.executeJavaScript('window.location.href');
                if (curUrl && curUrl !== mnLastUrl && curUrl !== 'about:blank') {
                  mnNavDetected = true;
                  // 用"点击后等"配置作为翻页后等待时间
                  await sleep(t.clickNextInterval || 3000);
                }
              } catch(e) { /* ignore */ }
            }
            if (batchLoadCancel) break;
          }
          if (!batchLoadCancel && t.status === 'loading') t.status = 'done';
        } else {
        // 等待页面真正加载完成
        var loaded = false;
        var loadPromise = new Promise(function(resolve) {
          var timeout = setTimeout(function() { if (!loaded) resolve(); }, 15000);
          function onLoad() {
            if (loaded) return;
            loaded = true;
            clearTimeout(timeout);
            webview.removeEventListener('did-finish-load', onLoad);
            setTimeout(resolve, 600); // 等渲染刷新
          }
          webview.addEventListener('did-finish-load', onLoad);
        });
        webview.loadURL(t.url);
        await loadPromise;
        // 基础间隔
        await sleep(parseInt($('#batchInterval').value) || 500);
        // 动态网页额外等待 JS 渲染
        var isDynamic = (document.querySelector('input[name="batchPageType"]:checked') || {}).value === 'dynamic';
        if (isDynamic) {
          var strategy = batchDynamicStrategy.value;
          if (strategy === 'networkIdle') {
            var idleMs = parseInt($('#batchDynamicIdleMs').value) || 2000;
            var maxIdleSec = parseInt($('#batchDynamicMaxWait').value) || 30;
            await waitForNetworkIdle(idleMs, maxIdleSec * 1000);
          } else if (strategy === 'waitSelector') {
            var waitSel = ($('#batchDynamicSelector').value || '').trim();
            var selMaxSec = parseInt($('#batchDynamicSelectorMaxWait').value) || 30;
            if (waitSel) await waitForSelector(waitSel, selMaxSec * 1000);
          } else {
            var extraWait = parseInt($('#batchWaitMs').value) || 3000;
            await sleep(extraWait);
          }
        }
        currentHtml = await webview.executeJavaScript('document.documentElement.outerHTML');
        if (currentHtml) {
          if (!/^local-html:\/\//i.test(t.url) && detectCaptcha(currentHtml, '')) {
            t.status = 'verify';
            t.error = '需要验证';
            batchLoadPaused = true;
            // 确保预览区可见
            webviewOverlay.classList.add('hidden');
            document.getElementById('panelRight').scrollIntoView();
            renderBatchTags();
            setStatus('遇到验证，请在右侧预览区手动通过验证后点击「继续」');
            break;
          }
          // 始终全量解析，存树数据到任务
          var respAll = await fetch('http://127.0.0.1:' + pythonPort + '/api/parse/all', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ html: currentHtml }),
          });
          if (!respAll.ok) throw new Error('解析失败: ' + respAll.status);
          var pdata = await respAll.json();
          t.parseData = pdata;

          var selector = t.selector || '';
          if (selector) {
            // 有选择器 → 额外 CSS 提取
            var respCss = await fetch('http://127.0.0.1:' + pythonPort + '/api/extract/css', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ html: currentHtml, query: selector, child_delim: globalChildDelim }),
            });
            if (!respCss.ok) throw new Error('CSS提取失败: ' + respCss.status);
            var cdata = await respCss.json();
            t.results = cdata.results || [];
          } else {
            t.results = [{ '页面标题': (currentHtml.match(/<title>(.*?)<\/title>/i) || [])[1] || '', '字符数': currentHtml.length, '脚本数': (pdata.scripts || []).length }];
          }
          t.rowCount = t.results.length;
          t.status = 'done';
          batchAllResults = batchAllResults.concat(t.results.map(function(r) {
            r._batchQ = t.q;
            r._batchPage = t.page;
            r._batchUrl = t.url;
            return r;
          }));
        }
        } // end else (non-clickNext)
      } catch (e) {
        // 重试逻辑：递减 i 让循环重新执行同一任务
        if (!t._retries) t._retries = 0;
        t._retries++;
        if (t._retries <= MAX_RETRIES && !batchLoadCancel) {
          t.status = 'retrying';
          t.error = '重试 ' + t._retries + '/' + MAX_RETRIES + ': ' + e.message;
          renderBatchTags();
          await sleep(RETRY_DELAY * t._retries);
          t.status = 'loading';
          i--; // 回退，重新执行当前任务
          continue;
        }
        t.status = 'error';
        t.error = e.message;
      }
      renderBatchTags();
      if (t.status === 'done' && i === batchTasks.length - 1) {
        // 最后一个任务完成后，树切换到对应页面
        if (t.parseData) { parseResult = t.parseData; buildTree(parseResult); }
        queryResults = batchAllResults;
        renderQueryTable(batchAllResults);
        contentTitle.textContent = '批量结果 (' + batchAllResults.length + '项)';
      }
    }
    batchCurrentTaskId = null;
    // 停止时把进行中的任务恢复
    if (batchLoadCancel) {
      batchTasks.forEach(function(t) { if (t.status === 'loading') t.status = 'pending'; });
      setStatus('批量抓取已停止');
    }
    batchLoadRunning = false;
    btnBatchLoadAll.textContent = '全部加载';
    btnBatchLoadAll.style.background = '';
    btnBatchLoadAll.style.borderColor = '';
    btnBatchLoadAll.style.color = '';
    renderBatchTags();
    if (!batchLoadPaused && !batchLoadCancel) setStatus('批量抓取完成');
  }

  function batchContinue() {
    if (batchLoadRunning) return;
    // 把 verify 的重新置为 pending
    batchTasks.forEach(function(t) { if (t.status === 'verify') t.status = 'pending'; });
    renderBatchTags();
    batchLoadAll();
  }

  function batchClearDone() {
    batchTasks = batchTasks.filter(function(t) { return t.status !== 'done'; });
    if (batchTasks.length === 0) {
      batchTagsPanel.classList.add('hidden');
      btnBatchLoadAll.classList.add('hidden');
      batchAllResults = [];
    }
    renderBatchTags();
  }

  // ── 笛卡尔积标签面板拖拽 & 自适应 ──

  function bindBatchTagsResize() {
    var resizeStartY, resizeStartH, resizeMinH;

    // 最后一个可见行在 treePanel 中的 bottom 偏移
    function getTreeLastBottom() {
      var treePanel = batchTagsPanel.parentElement;
      var panelTop = treePanel.getBoundingClientRect().top;
      var rows = treeContent.querySelectorAll(".tree-node-row, .tree-group-header");
      var maxB = 0;
      for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        // 跳过被折叠祖先包裹的行
        var p = r.parentElement;
        var hidden = false;
        while (p && p !== treeContent) {
          if (p.classList.contains("hidden") && (p.classList.contains("tree-children") || p.classList.contains("tree-group-body"))) { hidden = true; break; }
          p = p.parentElement;
        }
        if (hidden) continue;
        var rect = r.getBoundingClientRect();
        if (rect.height === 0) continue;
        var b = rect.bottom - panelTop;
        if (b > maxB) maxB = b;
      }
      return Math.max(maxB, 40);
    }

    // 自动贴合：折叠=面板放大，展开=面板缩小
    function autoFit() {
      if (batchTagsPanel.classList.contains("hidden")) return;
      var treePanel = batchTagsPanel.parentElement;
      var h = treePanel.clientHeight - getTreeLastBottom() - 6;
      if (h < 0) h = 0;
      batchTagsPanel.style.height = h + "px";
    }

    // 拖拽
    batchTagsResize.addEventListener("mousedown", function(e) {
      e.preventDefault();
      resizeStartY = e.clientY;
      resizeStartH = batchTagsPanel.offsetHeight;
      resizeMinH = 0;
      document.addEventListener("mousemove", onResizeMove);
      document.addEventListener("mouseup", onResizeUp);
    });

    function onResizeMove(e) {
      var delta = resizeStartY - e.clientY;
      var newH = resizeStartH + delta;
      if (newH < resizeMinH) newH = resizeMinH;
      var maxH = batchTagsPanel.parentElement.clientHeight - getTreeLastBottom() - 6;
      if (newH > maxH) newH = maxH;
      batchTagsPanel.style.height = newH + "px";
    }

    function onResizeUp() {
      document.removeEventListener("mousemove", onResizeMove);
      document.removeEventListener("mouseup", onResizeUp);
    }

    // 树内容变化自动贴合（展开/折叠节点）
    var fitPending = false;
    function scheduleFit() {
      if (fitPending) return;
      fitPending = true;
      requestAnimationFrame(function() { fitPending = false; autoFit(); });
    }
    var observer = new MutationObserver(scheduleFit);
    observer.observe(treeContent, { attributes: true, subtree: true, attributeFilter: ["style", "class"], childList: true });

    window.fitBatchPanelToTree = autoFit;
  }

