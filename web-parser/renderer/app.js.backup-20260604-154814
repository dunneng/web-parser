        preview.className = 'chain-preview';
        preview.style.marginLeft = '16px'; preview.style.maxHeight = '200px';
        preview.innerHTML = '<div class="tree-empty" style="padding:4px 0;font-size:11px">加载中...</div>';
        layerDiv.appendChild(preview);
