  function getSubChain(pIdx, subIdx) {
    var subs = chainSegments[pIdx] && chainSegments[pIdx].subChains;
    return (subs && subs[subIdx]) || null;
  }

  /** 绑定子链路区域内的动态事件（重新渲染后调用） */
