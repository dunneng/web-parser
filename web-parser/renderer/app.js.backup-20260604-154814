        var subType = (cssBtn && cssBtn.classList.contains('active')) ? 'css' : 'xpath';
        if (!sc) { chainSegments[idx].subChains.push({ selector: sel, chainType: subType, chainSegments: [] }); sc = chainSegments[idx].subChains[chainSegments[idx].subChains.length-1]; }
        else { sc.selector = sel; sc.chainType = subType; }
        parseSubChainSegments(idx, sel, subType, subIdx);
