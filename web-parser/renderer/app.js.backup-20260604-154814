  function addToEditor(elementInfo, selector, source, dragSession) {
    if (!selector && elementInfo && elementInfo.selectors && elementInfo.selectors.length > 0) {
      selector = elementInfo.selectors[0].selector;
    }
    if (!selector) selector = elementInfo.css || (elementInfo.tag || 'div');
    source = source || 'scan';

    // 扫描来源：过滤无文本、无链接、无图片的空壳元素
    if (source === 'scan') {
      var txt = (elementInfo.text || '').trim();
      var hasHref = !!(elementInfo.href || elementInfo.src);
      if (!txt && !hasHref) return;
    }

    // 去重 key：selector + src + href + text（用 normalizeText 清洗后截断）
    var dedupKey = selector + '||' + (elementInfo.src||'') + '||' + (elementInfo.href||'') + '||' + normalizeText(elementInfo.text||'').substring(0,maxCellText);
    var existsIdx = -1;
    for (var i = 0; i < editorItems.length; i++) {
      var item = editorItems[i];
      if (item._isTagHeader || !item.elementInfo) continue;
      var ik = item.selector + '||' + ((item.elementInfo.src)||'') + '||' + ((item.elementInfo.href)||'') + '||' + normalizeText(item.elementInfo.text||'').substring(0,maxCellText);
      if (ik === dedupKey) { existsIdx = i; break; }
    }
    if (existsIdx >= 0) {
      // 升级来源：pick/auto 可覆盖已有条目
      if ((source === 'pick' || source === 'auto') && editorItems[existsIdx].source !== source) {
        editorItems[existsIdx].source = source;
        editorItems[existsIdx].matchCount = (elementInfo.count != null && !isNaN(elementInfo.count)) ? elementInfo.count : 0;
        editorItems[existsIdx].dragSession = dragSession || 0;
        scheduleEditorRender();
        return;
      }
      // 同来源或非框选 → 去重跳过
      if (!dragSession) return;
      // 框选来源 → 同 session 去重，不同 session 允许重复
      if (editorItems[existsIdx].dragSession === dragSession) return;
      // 不同 session → fall through 允许添加
    }

    var count = (elementInfo.count != null && !isNaN(elementInfo.count)) ? elementInfo.count : 0;

    elementInfo.text = normalizeText(elementInfo.text || "");
    elementInfo.href = normalizeText(elementInfo.href || "");
    elementInfo.src = normalizeText(elementInfo.src || "");

    editorItems.push({
      elementInfo: elementInfo,
      selector: selector,
      xpath: elementInfo.xpath || elementInfo._xpath || '',
      matchCount: count,
      persisted: false,
      source: source,
      dragSession: dragSession || 0
    });

    scheduleEditorRender();
  }

  var _editorRenderTimer = null;
  function scheduleEditorRender() {
    if (_editorRenderTimer) clearTimeout(_editorRenderTimer);
    _editorRenderTimer = setTimeout(function () {
      _editorRenderTimer = null;
      updatePickedElementsFromEditor();
      renderElementEditor();
      updatePickedTreeNodes();
      syncQueryPanelIfPicked();
    }, 50);
  }

  function syncQueryPanelIfPicked() {
    var mode = queryContainer.dataset.mode;
    if (!mode || mode.indexOf('__picked') !== 0) return;
    var sourceFilter = null;
    if (mode !== '__picked__') {
      var m = mode.match(/^__picked_(.+?)__$/);
      sourceFilter = m ? m[1] : null;
    }
    var items = sourceFilter
      ? editorItems.filter(function (item) { return !item._isTagHeader && (item.source || 'scan') === sourceFilter; })
      : editorItems.filter(function(item) { return !item._isTagHeader; });
    var labels = { pick: '框选', auto: '识别', scan: '扫描', '合并': '合并', '拆分': '拆分' };
    renderQueryFromItems(items, labels);
  }

  function rematchSingleSelector(idx) {
    var item = editorItems[idx];
    if (!item || !item.selector) return;
    var selector = item.selector;

    setStatus('正在重新匹配: ' + selector);
    // 在 webview 中执行匹配
    webview.executeJavaScript('(function(sel){try{var els=document.querySelectorAll(sel);return els.length;}catch(e){return -1;}})(' + JSON.stringify(selector) + ')')
      .then(function (count) {
        item.matchCount = count >= 0 ? count : 0;
        // 同时更新 webview 中的高亮框
        if (count > 0) {
          webview.executeJavaScript('(function(sel,c){' +
            'var P=window.__parser;if(!P||!P.previewer)return;' +
            'P.previewer.highlight(sel,"#7c5cfc");' +
            'setTimeout(function(){P.previewer.clear();},1500);' +
            '})(' + JSON.stringify(selector) + ',' + count + ')');
        }
        renderElementEditor();
        syncQueryPanelIfPicked();
        setStatus(count > 0 ? '匹配成功: ' + count + ' 个元素' : '未匹配到元素');
      })
      .catch(function () {
        item.matchCount = 0;
        renderElementEditor();
        syncQueryPanelIfPicked();
        setStatus('匹配失败');
      });
  }

  function rematchAllSelectors() {
    if (editorItems.length === 0) return;
    setStatus('正在重新匹配所有选择器...');
    var pending = editorItems.length;
    var done = 0;
    editorItems.forEach(function (item, idx) {
      if (!item.selector) { pending--; return; }
      webview.executeJavaScript('(function(sel){try{var els=document.querySelectorAll(sel);return els.length;}catch(e){return -1;}})(' + JSON.stringify(item.selector) + ')')
        .then(function (count) {
          item.matchCount = count >= 0 ? count : 0;
          done++;
          if (done >= pending) {
            renderElementEditor();
            syncQueryPanelIfPicked();
            setStatus('全部重匹配完成');
          }
        })
        .catch(function () {
          item.matchCount = 0;
          done++;
          if (done >= pending) { renderElementEditor(); syncQueryPanelIfPicked(); }
        });
    });
    // 超时保护
    setTimeout(function () {
      renderElementEditor();
      syncQueryPanelIfPicked();
    }, 5000);
  }

  function updatePickedElementsFromEditor() {
    // 从 editorItems 同步到 pickedElements 供导出
