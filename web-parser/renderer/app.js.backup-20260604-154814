  /** 渲染链图层 */
  function renderChainLayers() {
    if (!schemaChainLayers) return;
    schemaChainLayers.innerHTML = '';
    chainSegments.forEach(function(seg, i) {
      // 兼容旧数据格式：单 attr/name → extractions 数组
      if (!seg.extractions) {
        seg.extractions = [];
        if (seg.attr || seg.name) {
          seg.extractions.push({ attr: seg.attr || '', name: seg.name || '' });
        }
        delete seg.attr;
        delete seg.name;
      }
      // 兼容旧数据：单 subChain → subChains 数组
      if (seg.subChain && !seg.subChains) {
        seg.subChains = [seg.subChain];
        delete seg.subChain;
      }
      if (!seg.subChains) seg.subChains = [];

      var wrap = document.createElement('div');
      wrap.className = 'schema-chain-layer-wrap';

      var div = document.createElement('div');
      div.className = 'schema-chain-layer';
      div.dataset.index = i;

      var hasSub = !!(seg.subChains && seg.subChains.length > 0);
      var expandIcon = hasSub ? '▼' : '▶';

      var tagLabel = seg.tag ? '<' + seg.tag + '>' : '?';

      div.innerHTML =
        '<span class="sc-col-level">' + (i + 1) + '</span>' +
        '<span class="sc-col-segment" title="' + escapeHtml(seg.selector) + '">' + escapeHtml(seg.selector) + '</span>' +
        '<span class="sc-col-tag">' + escapeHtml(tagLabel) + '</span>' +
        '<span class="sc-col-count"><span class="schema-field-count-val chain-count-val" data-idx="' + i + '">-</span></span>' +
        '<button class="btn-chain-sub-toggle" data-action="toggle-sub" data-idx="' + i + '" title="展开子链路配置">' + (hasSub ? '▼' : '▶') + '</button>';

      wrap.appendChild(div);

      // 提取属性行区域
      var extrSection = document.createElement('div');
      extrSection.className = 'chain-extract-section';
      extrSection.dataset.layerIdx = i;
      extrSection.id = 'chainExtract' + i;
      extrSection.innerHTML = renderExtractRows(i);
      wrap.appendChild(extrSection);

      // 属性预览面板（点击层行展开）
      var previewPanel = document.createElement('div');
      previewPanel.className = 'chain-preview hidden';
      previewPanel.dataset.previewIdx = i;
      previewPanel.innerHTML = '<div class="tree-empty" style="padding:4px 0;font-size:11px">加载中...</div>';
      wrap.appendChild(previewPanel);

      // 子链路区域
      var subSection = document.createElement('div');
      subSection.className = 'chain-sub-section';
      if (!hasSub) subSection.classList.add('hidden');
      subSection.dataset.parentIdx = i;
      subSection.innerHTML = renderSubChainHTML(i);
      wrap.appendChild(subSection);

      schemaChainLayers.appendChild(wrap);
    });

    // 绑定事件 — 属性选择
    schemaChainLayers.querySelectorAll('.chain-attr-select').forEach(function(sel) {
      sel._prevValue = sel.value || '';
      sel.addEventListener('change', function() {
        var layerIdx = parseInt(this.dataset.layerIdx);
        var extrIdx = parseInt(this.dataset.idx);
        var ext = chainSegments[layerIdx].extractions[extrIdx];
        if (!ext) return;
        if (this.value === '__custom__') {
          handleCustomAttr(this, function(val) {
            ext.attr = val;
            autoRefreshChainPreview();
          });
        } else {
          this._prevValue = this.value;
          ext.attr = this.value;
          autoRefreshChainPreview();
        }
      });
    });
