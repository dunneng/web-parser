  function loadStealthConfig() {
    try {
      var raw = localStorage.getItem('stealth_scripts');
      _stealthData = raw ? JSON.parse(raw) : {};
    } catch (e) { _stealthData = {}; }
    if (!_stealthData.defaultScripts) {
      _stealthData.defaultScripts = STEALTH_SCRIPTS.filter(function(s) { return s.defaultOn; }).map(function(s) { return s.id; });
    }
    if (!_stealthData.domains) _stealthData.domains = {};
  }
  function saveStealthConfig() {
    try { localStorage.setItem('stealth_scripts', JSON.stringify(_stealthData)); } catch (e) {}
  }
  function getStealthScriptsForHost(host) {
    if (!host) return _stealthData.defaultScripts || [];
    // 精确匹配或父域名匹配
    if (_stealthData.domains[host]) return _stealthData.domains[host];
    var parts = host.split('.');
    for (var i = 1; i < parts.length; i++) {
      var parent = parts.slice(i).join('.');
      if (_stealthData.domains[parent]) return _stealthData.domains[parent];
    }
    return _stealthData.defaultScripts || [];
  }

  // ── 反爬脚本：注入到 webview ──
  function injectStealthConfig(host) {
    var scripts = getStealthScriptsForHost(host);
    var injectScripts = scripts.filter(function(id) { return STEALTH_INJECT_IDS.indexOf(id) !== -1; });
    var configJSON = JSON.stringify({ scripts: injectScripts, host: host || '' });
    // 1. 注入配置（让 preload 中的基础伪装可读取）
    webview.executeJavaScript(
      '(function(){window.__parser=window.__parser||{};window.__parser._stealthConfig=' + configJSON + ';})()'
    ).catch(function() {});
    // 2. 注入原型包装脚本（在页面上下文执行，能修改原型链）
    injectStealthPrototypes(injectScripts);
  }

